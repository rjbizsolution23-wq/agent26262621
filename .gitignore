# Ignore all markdown files by default
*.md

# Whitelist clean compliance, governance, and project documentation
!README.md
!CLA.md
!CODE_OF_CONDUCT.md
!CONTRIBUTING.md
!GOVERNANCE.md
!SUPPORT.md
!SECURITY.md
!CHANGELOG.md
!walkthrough.md
!implementation_plan.md
!docs/
!docs/*.md

# Exclude .env and environment files
.env
.env.*
!.env.example

# Logs and databases
*.log
*.sqlite
__pycache__/
*.pyc

# Local system files
.DS_Store
Thumbs.db

# Exclude all python files by default except our SASO code
*.py
!run_saso.py
!saso_bridge.py
!saso_orchestrator.py
!saso_registry.py
!saso_router.py
!saso_server.py
!python_harness.py

# Python environments
.venv/
env/
venv/
ENV/
